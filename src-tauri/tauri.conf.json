{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LocalSpend",
  "version": "0.1.0",
  "identifier": "com.localspend.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalSpend",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Finance"
  }
}
